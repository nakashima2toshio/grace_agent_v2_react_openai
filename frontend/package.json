{
  "name": "grace-agent-support-ui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:e2e": "vitest run src/test/e2e.test.tsx",
    "types:generate": "openapi-typescript openapi.json -o src/types/generated.ts",
    "types:check": "npm run types:generate && git diff --exit-code -- openapi.json src/types/generated.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "openapi-typescript": "^7.13.0",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
